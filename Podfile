source 'https://github.com/CocoaPods/Specs.git'
source 'git@gitlab.3squared.com:iOSLibraries/CocoaPodSpecs.git'

target 'Meadow-iOS' do

	platform :ios, '11.3'

	pod 'Pasture', :path => '../Pasture'
  pod 'Terrace', :path => '../Terrace'

  target 'Meadow-iOSTests' do
    
  	inherit! :search_paths
    
  end

end

target 'Meadow-macOS' do

	platform :osx, '10.13'

	pod 'Pasture', :path => '../Pasture'
  pod 'Terrace', :path => '../Terrace'

  target 'Meadow-macOSTests' do
    
  	inherit! :search_paths
    
  end

end